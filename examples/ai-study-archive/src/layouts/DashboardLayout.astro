---
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  current: "articles" | "categories" | "media" | "glossary" | "faq" | "settings";
}
const { title, current } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AI Study</title>
    <meta name="description" content="AIスタディの記録を蓄積・閲覧する個人用アーカイブ" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-grey-50 min-h-screen">
    <div class="flex h-screen">
      <Sidebar current={current} />
      <main class="flex-1 bg-grey-50 overflow-y-auto">
        <div class="max-w-7xl mx-auto px-8 py-12">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
