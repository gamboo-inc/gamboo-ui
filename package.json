{
  "name": "melta-ds-mcp",
  "version": "1.3.0",
  "description": "melta UI — AI-Ready Design System with MCP server (design tokens, component contracts, prohibition rules, check_html self-verification)",
  "type": "module",
  "mcpName": "io.github.tsubotax/melta-ui",
  "keywords": [
    "design-system",
    "mcp",
    "mcp-server",
    "ai-ready",
    "design-tokens",
    "tailwind",
    "melta"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsubotax/melta-ui.git"
  },
  "homepage": "https://melta.tsubotax.com",
  "bin": {
    "melta-ds-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "design/contracts/tokens.json",
    "design/contracts/tokens.dtcg.json",
    "design/contracts/rules.json",
    "design/contracts/components",
    "metadata",
    "DESIGN.md",
    "AGENTS.md",
    "design/contracts/recipes"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "tsx tools/generate-css.ts && tsx tools/generate-tailwind.ts && tsx tools/generate-pen-variables.ts",
    "validate": "tsx tools/validate-tokens.ts",
    "design:check": "tsx scripts/design/validate.ts",
    "design:lint-generated": "tsx scripts/design/lint-generated.ts",
    "design:drift": "tsx scripts/design/drift-check.ts",
    "design:drift-heal": "tsx scripts/design/loops/drift-heal.ts",
    "design:update-showcase": "tsx scripts/design/update-showcase.ts",
    "design:build": "tsx scripts/design/build-legacy.ts && tsx scripts/design/export-designmd.ts && tsx scripts/design/export-dtcg.ts && tsx scripts/design/export-recipes.ts && tsx scripts/design/build-llms-txt.ts && tsc",
    "design:llms": "tsx scripts/design/build-llms-txt.ts",
    "design:designmd": "tsx scripts/design/export-designmd.ts",
    "design:designmd-lint": "tsx scripts/design/designmd-lint.ts",
    "design:dtcg": "tsx scripts/design/export-dtcg.ts",
    "design:coverage": "tsx scripts/design/coverage-stats.ts",
    "test": "playwright test",
    "benchmark": "tsx design/benchmarks/runner.ts",
    "postversion": "tsx scripts/design/update-showcase.ts && tsx scripts/design/build-llms-txt.ts && git add docs/index.html llms.txt llms-full.txt",
    "start": "node dist/index.js",
    "design:compat": "tsx scripts/design/contract-compat.ts",
    "design:recipes": "tsx scripts/design/export-recipes.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.3",
    "http-server": "^14.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
