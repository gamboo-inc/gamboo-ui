{
  "name": "@melta/design-system",
  "version": "1.3.0",
  "description": "melta UI — AI-Ready Design System with MCP server",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsubotax/melta-ui.git"
  },
  "homepage": "https://melta.tsubotax.com",
  "bin": {
    "melta-ds-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx tools/generate-css.ts && tsx tools/generate-tailwind.ts && tsx tools/generate-pen-variables.ts",
    "validate": "tsx tools/validate-tokens.ts",
    "design:check": "tsx scripts/design/validate.ts",
    "design:lint-generated": "tsx scripts/design/lint-generated.ts",
    "design:drift": "tsx scripts/design/drift-check.ts",
    "design:update-showcase": "tsx scripts/design/update-showcase.ts",
    "design:build": "tsx scripts/design/build-legacy.ts && tsc",
    "test": "playwright test",
    "benchmark": "tsx design/benchmarks/runner.ts",
    "postversion": "tsx scripts/design/update-showcase.ts && git add docs/index.html",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.3",
    "http-server": "^14.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
