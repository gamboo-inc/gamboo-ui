{
  "$schema": "../../../schemas/recipe.schema.json",
  "id": "text",
  "platform": "app",
  "contractVersion": "0.1.0",
  "description": "RN 実装（src/primitives/Text.tsx）の具象レシピ（styleRefs 形式）。variant = fontSize 段階。fontSize token は fontSize/lineHeight の複合値として解決する。letterSpacing は typography.letterSpacing.{heading|body}（em 比率）を fontSize から pt 換算して適用（role prop で切替、default body）。文字色は prop（semantic token キー限定、default color.semantic.light.text-default）、weight も prop（typography.fontWeight.* キー限定）で、variant には依存しない。",
  "variants": {
    "xs": {
      "style": { "fontSize": { "token": "typography.fontSize.xs" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "sm": {
      "style": { "fontSize": { "token": "typography.fontSize.sm" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "base": {
      "style": { "fontSize": { "token": "typography.fontSize.base" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "lg": {
      "style": { "fontSize": { "token": "typography.fontSize.lg" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "xl": {
      "style": { "fontSize": { "token": "typography.fontSize.xl" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "2xl": {
      "style": { "fontSize": { "token": "typography.fontSize.2xl" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    },
    "3xl": {
      "style": { "fontSize": { "token": "typography.fontSize.3xl" }, "letterSpacing": { "token": "typography.letterSpacing.body" } }
    }
  },
  "sizes": {},
  "states": {}
}
