{
  "$schema": "../schemas/component-contract.schema.json",
  "id": "dropdown",
  "version": "2.0.0",
  "name": "Dropdown",
  "category": "navigation",
  "intent": "ドロップダウンメニュー。キーボードナビゲーション対応。",
  "docPath": "components/dropdown.md",
  "anatomy": ["triggerButton", "menuContainer", "menuItem", "leadingIcon?", "separator?", "menuGroupLabel?"],
  "variants": {
    "basic": {
      "description": "テキストのみのシンプルなメニュー",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "border": "color.semantic.light.border-default",
        "elevation": "elevation.md",
        "radius": "radius.md",
        "z": "zIndex.dropdown"
      },
      "tailwind": "absolute top-full mt-1 w-48 bg-white rounded-lg border border-slate-200 shadow-md z-20 py-1"
    },
    "with-icons": {
      "description": "アイコン付きメニューアイテム",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "border": "color.semantic.light.border-default",
        "elevation": "elevation.md",
        "radius": "radius.md",
        "z": "zIndex.dropdown"
      },
      "tailwind": "absolute top-full mt-1 w-48 bg-white rounded-lg border border-slate-200 shadow-md z-20 py-1"
    },
    "with-separator": {
      "description": "セパレータでグループ分けされたメニュー",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "border": "color.semantic.light.border-default",
        "elevation": "elevation.md",
        "radius": "radius.md",
        "z": "zIndex.dropdown"
      },
      "tailwind": "absolute top-full mt-1 w-48 bg-white rounded-lg border border-slate-200 shadow-md z-20 py-1"
    }
  },
  "sizes": {},
  "states": [
    "default",
    "open",
    "hover",
    "focus",
    "disabled",
    "destructive"
  ],
  "a11y": {
    "role": "menu",
    "required": [
      "role=\"menuitem\" on items",
      "aria-haspopup on trigger"
    ],
    "keyboard": ["ArrowDown", "ArrowUp", "Home", "End", "Escape", "Tab"],
    "focusRing": "focus-visible:ring-2 focus-visible:ring-primary-500/50"
  },
  "rules": [],
  "htmlSample": "<div class=\"relative inline-block\"><button aria-haspopup=\"menu\" class=\"h-10 px-4 bg-white border border-slate-200 rounded-lg hover:bg-gray-50\">メニュー</button><div role=\"menu\" class=\"absolute top-full mt-1 w-48 bg-white rounded-lg border border-slate-200 shadow-md z-20 py-1\"><a role=\"menuitem\" class=\"flex items-center gap-3 px-4 py-2 text-sm text-body hover:bg-gray-50\">編集</a></div></div>"
}
