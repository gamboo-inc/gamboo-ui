      "severity": "error"
    },
    {
      "id": "SKELETON_BG_SLATE_200_ONLY",
      "severity": "error"
    },
    {
      "id": "MOTION_REDUCED_MOTION_REQUIRED",
      "severity": "error"
    }
  ],
  "htmlSample": "<div aria-busy=\"true\" role=\"status\" aria-label=\"読み込み中\" class=\"bg-slate-200 rounded-md h-4 w-full skeleton-pulse\"></div>"
