  "intent": "ローディングプレースホルダー。aria-busy=\"true\"必須。",
  "docPath": "components/skeleton.md",
  "anatomy": ["container", "circle?", "bar", "srOnlyText"],
  "variants": {
    "text": {
      "description": "テキスト行のプレースホルダー",
      "tokenRefs": {
