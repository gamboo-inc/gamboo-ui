{
  "$schema": "../schemas/component-contract.schema.json",
  "id": "modal",
  "version": "2.0.0",
  "name": "Modal",
  "category": "feedback",
  "intent": "フォーカストラップとバックドロップを備えたモーダルダイアログ。",
  "docPath": "components/modal.md",
  "anatomy": ["overlay", "container", "header", "body", "footer?", "closeButton"],
  "variants": {
    "confirmation": {
      "description": "確認ダイアログ",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "radius": "radius.lg",
        "elevation": "elevation.overlay"
      },
      "tailwind": "fixed inset-0 flex items-center justify-center z-50"
    },
    "form": {
      "description": "フォーム入力ダイアログ",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "radius": "radius.lg",
        "elevation": "elevation.overlay"
      },
      "tailwind": "fixed inset-0 flex items-center justify-center z-50"
    },
    "alert": {
      "description": "警告ダイアログ",
      "tokenRefs": {
        "bg": "color.semantic.light.bg-surface",
        "radius": "radius.lg",
        "elevation": "elevation.overlay"
      },
      "tailwind": "fixed inset-0 flex items-center justify-center z-50"
    }
  },
  "sizes": {
    "small":  { "height": 0, "tailwind": "w-96" },
    "medium": { "height": 0, "tailwind": "w-[32rem]" },
    "large":  { "height": 0, "tailwind": "w-[48rem]" }
  },
  "states": ["default", "open", "closing"],
  "a11y": {
    "role": "dialog",
    "required": ["aria-labelledby", "aria-modal=\"true\"", "focus trap"],
    "keyboard": ["Escape", "Tab", "Shift+Tab"],
    "focusRing": "focus trap required"
  },
  "rules": [
    { "id": "MODAL_FOCUS_TRAP_REQUIRED", "severity": "error" },
    { "id": "MODAL_ESC_CLOSE_REQUIRED", "severity": "error" },
    { "id": "MODAL_CLOSE_REQUIRED", "severity": "error" },
    { "id": "MODAL_ROLE_DIALOG_REQUIRED", "severity": "error" },
    { "id": "MODAL_OVERLAY_REQUIRED", "severity": "error" },
    { "id": "MODAL_NO_NESTED", "severity": "error" }
  ],
  "htmlSample": {
    "confirmation": "<div role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modal-title\" class=\"fixed inset-0 flex items-center justify-center z-50\"><div class=\"bg-black/50 absolute inset-0\"></div><div class=\"bg-white rounded-xl p-6 w-96 shadow-xl relative z-10\"><h2 id=\"modal-title\" class=\"text-2xl font-bold text-slate-900\">確認</h2><p class=\"text-body mt-2\">この操作を実行しますか？</p><div class=\"flex justify-end gap-3 mt-6\"><button class=\"inline-flex items-center justify-center h-10 px-4 text-[1rem] font-medium bg-white text-slate-700 border border-slate-200 rounded-lg hover:bg-gray-50 cursor-pointer\">キャンセル</button><button class=\"inline-flex items-center justify-center h-10 px-4 text-[1rem] font-medium bg-primary-500 text-white rounded-lg hover:bg-primary-700 cursor-pointer\">実行</button></div></div></div>"
  }
}
