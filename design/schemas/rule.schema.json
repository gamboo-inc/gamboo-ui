{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "melta UI Rule Registry",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "severity", "description", "detector", "alternative", "contractLint"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]+$",
            "description": "ルール ID（大文字スネーク）"
          },
          "category": {
            "type": "string",
            "enum": ["color", "philosophy", "motion", "typography", "spacing", "ai-pattern", "button", "form", "modal", "list", "table", "tag", "divider", "stepper", "datepicker", "skeleton", "accessibility"]
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warn"]
          },
          "description": { "type": "string" },
          "detector": {
            "type": "string",
            "enum": ["tailwind-class", "tailwind-class-prefix", "tailwind-class-segment", "html-attr", "composition", "manual"],
            "description": "検出方式。manual は自動検出不可。tailwind-class-segment は base を-分割し matchPatterns と segment 一致。composition は DOM をパースして要素間の関係・ネスト・色数を判定（compositionCheck spec が必要）"
          },
          "pattern": {
            "type": ["string", "null"],
            "description": "Tailwind クラスの検出パターン。manual detector の場合 null"
          },
          "matchPatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "prefix 検出用の具体的なマッチパターン一覧"
          },
          "prefixPatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "tailwind-class-prefix 専用の純粋な前方一致パターン一覧（bg-[rgb( 等の任意値回避経路の検知用）。matchPatterns は完全一致 + /modifier のみで意味論が異なる"
          },
          "alternative": { "type": "string" },
          "contractLint": {
            "type": "string",
            "enum": ["enforce", "warn", "skip"],
            "description": "P1b contract lint での適用方針。enforce=違反検出、warn=警告のみ、skip=対象外（manual/html-attr/文脈依存ルール）"
          },
          "requiresContext": {
            "type": "boolean",
            "description": "true の場合、ルールは特定の文脈でのみ NG。contract lint からは skip するが、AI には参照させたい"
          },
          "htmlAttrCheck": {
            "type": "object",
            "description": "detector=html-attr のうち機械判定できるものに付与（Q5）。正規表現ベースの属性検査 spec",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["attr-value-forbidden", "attr-value-contains", "tag-missing-attr", "element-present", "tag-present"] },
              "attr": { "type": "string" },
              "valueRegex": { "type": "string" },
              "tag": { "type": "string" },
              "requiredAttr": { "type": "string" },
              "attrValue": { "type": "string" }
            }
          },
          "compositionCheck": {
            "type": "object",
            "description": "detector=composition に付与（S2）。DOM をパースして合成（ネスト/関係/a11y属性）を判定する spec",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["nested-selector", "dom-attr-required"] },
              "selector": { "type": "string" },
              "requireAnyAttr": { "type": "array", "items": { "type": "string" }, "description": "dom-attr-required: このいずれかの属性が必須" },
              "scope": { "type": "string", "enum": ["self", "ancestor-or-self"], "description": "dom-attr-required: 属性の存在場所（既定 self）" },
              "when": { "type": "string", "enum": ["icon-only", "text-glyph"], "description": "dom-attr-required: 候補を絞る述語" },
              "glyphs": { "type": "array", "items": { "type": "string" }, "description": "when=text-glyph 用のグリフ集合" }
            }
          },
          "automationStatus": {
            "type": "string",
            "enum": ["auto", "covered-by-test", "impossible-static"],
            "description": "自動検証の状態（P1-5）。impossible-static は意味依存で静的検出不能（カバレッジ分母から除外）"
          }
        }
      }
    }
  }
}
