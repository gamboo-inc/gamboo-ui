{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "melta UI Component Contract",
  "type": "object",
  "required": ["id", "version", "name", "category", "intent", "variants", "sizes", "states", "a11y", "rules"],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "コンポーネント ID（kebab-case）"
    },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["form-input", "data-display", "feedback", "layout", "navigation"]
    },
    "intent": { "type": "string" },
    "docPath": { "type": "string" },
    "appFirst": {
      "type": "boolean",
      "description": "app(RN)先行定義の contract。web(melta-ui)実装より先に app で定義したもの。"
    },
    "webStatus": {
      "type": "string",
      "enum": ["pending", "implemented"],
      "description": "web 実装の状態。pending = app 先行で web 未実装（drift-check が docPath / showcase 突合を skip）。"
    },
    "anatomy": {
      "comment": "Phase1 移行形: 簡易コンポーネントは string[]、複合（modal/table 等）は {part:{description,element?,roles?,tailwind?}} の object。手書き validate.ts は oneOf 非対応のため type-array で表現する。inner part の deep-validate は Phase2 の ajv 導入時。",
      "type": ["array", "object"]
    },
    "variants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "tailwind"],
        "properties": {
          "description": { "type": "string" },
          "tokenRefs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "tailwind": { "type": "string" }
        }
      }
    },
    "sizes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["height", "tailwind"],
        "properties": {
          "height": { "type": "number" },
          "tailwind": { "type": "string" },
          "icon": { "type": "number" }
        }
      }
    },
    "iconButton": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tailwind": { "type": "string" },
          "icon": { "type": "string" }
        }
      }
    },
    "iconTextPadding": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tailwind": { "type": "string" }
        }
      }
    },
    "states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stateSpecs": {
      "comment": "state ごとの生成仕様（opt-in / additive）。keys(stateSpecs) ⊆ states[] が validate.ts の同期チェックで担保される（subset=error / states に spec 無し=warn）。tailwind は **variant 基底からの差分のみ**（state が variant tailwind をそのまま再掲したら validate が warn=差分は空文字にする）。state は2種: (1) overlay 状態（disabled/loading/hover/focus 等）= variant の上に重ねる加算差分。(2) structural 状態（open/closing/empty/expanded 等）= 表示モードを切替。variant が基底状態を表すなら open 等の差分は空文字でよい（例: modal は variant=開いた姿なので open.tailwind=\"\"、default=\"hidden\" の上書き、closing=フェード差分）。variant 依存の hover/focus は variants[].tailwind が正本なので stateSpecs に入れない（disabled が overlay 状態の floor）。",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "tailwind"],
        "properties": {
          "description": { "type": "string" },
          "tailwind": { "type": "string" },
          "ariaChanges": { "type": "string" },
          "htmlNote": { "type": "string" }
        }
      }
    },
    "a11y": {
      "type": "object",
      "required": ["role", "required", "keyboard"],
      "properties": {
        "role": { "type": "string" },
        "required": { "type": "array", "items": { "type": "string" } },
        "keyboard": { "type": "array", "items": { "type": "string" } },
        "focusRing": { "type": "string" }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warn"] }
        }
      }
    },
    "htmlSample": {
      "type": ["string", "object"]
    }
  }
}
